APP_NAME="Madhavi Stores"
APP_ENV=production
APP_KEY=                          # php artisan key:generate
APP_DEBUG=false
APP_URL=https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error                   # error only in production

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=                      # Hostinger MySQL DB name
DB_USERNAME=                      # Hostinger MySQL username
DB_PASSWORD=                      # Hostinger MySQL password

SESSION_DRIVER=database          # NOT file — file sessions lock per request and
                                 # serialise a user's concurrent AJAX cart calls.
                                 # The sessions table already exists via migrations.
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true       # REQUIRED over HTTPS — cookie only sent on https
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database         # requires jobs table + scheduler cron

CACHE_STORE=file                  # use file cache on shared hosting (no Redis)

MAIL_MAILER=smtp
MAIL_SCHEME=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=                    # your Gmail address
MAIL_PASSWORD=                    # NEW Gmail App Password (revoke old one first)
MAIL_FROM_ADDRESS=                # your Gmail address
MAIL_FROM_NAME="Madhavi Stores"

VITE_APP_NAME="${APP_NAME}"

INSTAGRAM_ACCESS_TOKEN=           # NEW token (invalidate old one in Meta Developer Console)
INSTAGRAM_BUSINESS_ACCOUNT_ID=

RAZORPAY_KEY_ID=                  # LIVE key from Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_SECRET=              # LIVE secret from Razorpay Dashboard
RAZORPAY_WEBHOOK_SECRET=          # Dashboard → Settings → Webhooks. Add a webhook for
                                  # event "payment.captured" pointing at:
                                  #   https://yourdomain.com/webhooks/razorpay
                                  # so an order is still created if the buyer closes
                                  # the tab after paying. Leave blank to disable.

# ─── Hostinger cron job to add in hPanel ────────────────────────
# Runs the scheduler every minute. The scheduler in turn drives queue:work
# (OTP + invoice emails) and the otp:cleanup / session:gc tasks. Without this
# cron, queued emails will NEVER be sent.
# * * * * * php /home/username/public_html/artisan schedule:run >> /dev/null 2>&1
# ────────────────────────────────────────────────────────────────

# PRE-LAUNCH CHECKLIST (do these before going live):
#  1. Revoke the OLD Gmail App Password in your Google Account, generate a new one.
#  2. Invalidate the OLD Instagram token in the Meta Developer Console.
#  3. Run: php artisan key:generate   (fills APP_KEY above; logs everyone out).
#  4. Run: php artisan migrate --force
#  5. Confirm APP_ENV=production and APP_DEBUG=false (a mock-payment bypass is
#     active when APP_ENV=local — it MUST be production here).
#  6. Add the scheduler cron (above) and confirm a test email actually arrives.
